/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode*dummy=new ListNode();
        ListNode*curr=dummy;
        int carry=0;
        while(l1!=NULL and l2!=NULL){
            int sum=l1->val+l2->val+carry;
            if(sum>=10){
                int curr_sum=sum%10;
                curr->next=new ListNode(curr_sum);
                curr=curr->next;
                carry=1;
            }
            else{
               
                curr->next=new ListNode(sum);
                curr=curr->next;
                carry=0;
            }
            l1=l1->next;
            l2=l2->next;
        }
        while(l1!=NULL){
            int sum=l1->val+carry;
            if(sum>=10){
                int curr_sum=sum%10;
                curr->next=new ListNode(curr_sum);
                curr=curr->next;
                carry=1;
            }
            else{
               
                curr->next=new ListNode(sum);
                curr=curr->next;
                carry=0;
            }
            l1=l1->next;
        }
        while(l2!=NULL){
            int sum=l2->val+carry;
            if(sum>=10){
                int curr_sum=sum%10;
                curr->next=new ListNode(curr_sum);
                curr=curr->next;
                carry=1;
            }
            else{
               
                curr->next=new ListNode(sum);
                curr=curr->next;
                carry=0;
            }
            l2=l2->next;
        }
        if(carry==1){
            curr->next=new ListNode(1);
        }
        return dummy->next;
    }
};
